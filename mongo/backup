To backup all databases:
docker exec yggdrasil-mongo-1 sh -c 'mongodump --archive --username yggdrasil-admin --password yggdr4s1L-p45Sf1tT4 --authenticationDatabase admin' > db.dump

To resore everything from db.dump:
docker exec -i yggdrasil-mongo-1 sh -c 'mongorestore --archive --username yggdrasil-admin --password yggdr4s1L-p45Sf1tT4 --authenticationDatabase admin' < db.dump
